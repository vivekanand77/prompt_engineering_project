// ─── Firestore Security Rules ────────────────────────────────
// Deploy these in Firebase Console → Firestore → Rules
//
// These rules enforce:
// 1. Users can only read/write their own data
// 2. All other paths are denied
// 3. Document size limits enforced
// ──────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User-scoped data: prompts + progress
    match /users/{userId}/{document=**} {
      // Read: must be authenticated as this user
      allow read: if request.auth != null && request.auth.uid == userId;

      // Create / Update: authenticated as this user, reasonable field count
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.data.keys().size() < 50;

      // Delete: authenticated as this user (no request.resource on deletes)
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
